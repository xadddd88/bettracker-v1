{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "build/provider-smoke",
    "rootDir": ".",
    "noEmit": false
  },
  "include": ["lib/providers/**/*.ts", "lib/env.ts", "scripts/provider-smoke.ts"]
}
