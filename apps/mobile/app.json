{
  "expo": {
    "name": "xaddd",
    "slug": "xaddd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/android-icon-monochrome.png",
    "scheme": "xaddd",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/android-icon-monochrome.png",
      "bundleIdentifier": "com.dmitriykhodakivskyi.xaddd"
    },
    "android": {
      "package": "com.dmitriykhodakivskyi.xaddd",
      "icon": "./assets/images/android-icon-monochrome.png",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/android-icon-monochrome.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
