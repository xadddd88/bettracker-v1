{
  "expo": {
    "name": "BetTracker",
    "slug": "xaddd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/bettracker-icon.png",
    "scheme": "xaddd",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#070A08",
    "primaryColor": "#BFFF3B",
    "ios": {
      "icon": "./assets/brand/bettracker-icon.png",
      "backgroundColor": "#070A08",
      "bundleIdentifier": "com.dmitriykhodakivskyi.xaddd",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.dmitriykhodakivskyi.xaddd",
      "backgroundColor": "#070A08",
      "icon": "./assets/brand/bettracker-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/bettracker-adaptive-foreground.png",
        "monochromeImage": "./assets/brand/bettracker-monochrome.png",
        "backgroundColor": "#070A08"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/bettracker-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#070A08",
          "dark": {
            "backgroundColor": "#070A08",
            "image": "./assets/brand/bettracker-splash-mark.png"
          },
          "image": "./assets/brand/bettracker-splash-mark.png",
          "imageWidth": 112
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow BetTracker to photograph a coupon or event screenshot for local preparation.",
          "photosPermission": "Allow BetTracker to choose a coupon or event screenshot for local preparation.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b830dceb-1f96-4c09-b02d-fd2415c14a02"
      }
    },
    "owner": "xaddds-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b830dceb-1f96-4c09-b02d-fd2415c14a02"
    }
  }
}
